{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"files": {
		"includes": [
			"**",
			"!**/package-lock.json",
			"!**/node_modules",
			"!/nix/store",
			"!**/.devbox/state.json"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}
